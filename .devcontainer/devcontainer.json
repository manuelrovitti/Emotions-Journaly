{
	"name": "Node.js",

	"image": "mcr.microsoft.com/devcontainers/javascript-node:4-24-trixie",

	"customizations": {
		"vscode": {
			"extensions": [
				"Vue.volar",
				"mechatroner.rainbow-csv"
			]
		}
	},

	"features": {
		"ghcr.io/devcontainers/features/python:1": {
			"version": "3.11"
		}
	},

	"forwardPorts": [5173, 8000],

	// NETWORK ISSUES
	"runArgs": [
		"--dns=8.8.8.8",
		"--dns=1.1.1.1"
	],

	"containerEnv": {
		"NODE_OPTIONS": "--dns-result-order=ipv4first"
	},

	"postCreateCommand": "python -m pip install -r .devcontainer/requirements.txt"
}